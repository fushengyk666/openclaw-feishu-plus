{
  "name": "openclaw-feishu-plus",
  "version": "0.2.0",
  "description": "飞书增强插件：dual-token 自动切换（user-if-available-else-tenant），支持完整飞书平台能力",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/ --ext .ts",
    "verify": "npm run build && npx tsc --noEmit && for f in tests/*.ts; do echo \"--- $f\"; node --import=tsx \"$f\" || exit 1; done"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "tsx": "^4.19.4"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "channel": {
      "id": "openclaw-feishu-plus",
      "label": "Feishu Plus",
      "selectionLabel": "Feishu/Lark (飞书)",
      "docsPath": "/channels/feishu-plus",
      "docsLabel": "feishu-plus",
      "blurb": "飞书/Lark 企业消息与文档工具，支持 dual-token 自动切换。",
      "aliases": ["lark", "feishu-plus"],
      "order": 36
    },
    "install": {
      "npmSpec": "openclaw-feishu-plus",
      "localPath": "extensions/feishu-plus",
      "defaultChoice": "local"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
